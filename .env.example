# =====================================================
# Örnek environment dosyası.
# Gerçek değerleri .env içine kopyalayın (bu dosya git'e gider, .env gitmez).
# =====================================================

# -- MongoDB Bağlantısı --
MONGODB_URI=mongodb://localhost:27017/safe_drive

# -- JWT (Token) --
JWT_SECRET=cok-gizli-bir-anahtar-buraya-yazilmali-min-32-karakter
JWT_EXPIRES_IN=7d

# -- Server --
PORT=5000
NODE_ENV=development

# -- CORS izinli origin (dashboard adresi) --
CORS_ORIGIN=http://localhost:5173

# -- Bcrypt salt rounds (10 makul, 12 daha güvenli ama yavaş) --
BCRYPT_SALT_ROUNDS=10
